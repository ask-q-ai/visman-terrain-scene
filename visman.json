          }
        }
      }
    },
    {
      "id": "heightmap-terrain",
      "context": "threejs",
      "type": "terrain",
      "position": {
        "x": 30,
        "y": 0,
        "z": 0
      },
      "size": {
        "width": 50,
        "height": 50
      },
      "style": {
        "color": "#8b4513"
      },
      "properties": {
        "terrainConfig": {
          "segments": 128,
          "heightMapUrl": "https://raw.githubusercontent.com/mrdoob/three.js/master/examples/textures/terrain/heightmap.png",
          "heightScale": 12
        },
        "textureUrl": "https://raw.githubusercontent.com/mrdoob/three.js/master/examples/textures/terrain/grasslight-big.jpg"
      }
    }
  ]
