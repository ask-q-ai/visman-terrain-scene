{
  "background": {
    "color": "#8EBADF"
  },
  "atmosphere": {
    "preset": "day",
    "fogColor": "#AFCDE7",
    "fogNear": 70,
    "fogFar": 360,
    "exposure": 1.02
  },
  "camera": {
    "position": {
      "x": 0,
      "y": 40,
      "z": 60
    },
    "lookAt": {
      "x": 0,
      "y": 0,
      "z": 0
    },
    "fov": 60,
    "enableControls": true
  },
  "lights": [
    {
      "id": "terrain-ambient",
      "type": "ambient",
      "color": 16777215,
      "intensity": 1.0
    },
    {
      "id": "terrain-directional",
      "type": "directional",
      "color": 16777215,
      "intensity": 2.0,
      "position": {
        "x": 10,
        "y": 20,
        "z": 10
      }
    }
  ],
  "threeJsLayer": [
    {
      "id": "procedural-terrain",
      "context": "threejs",
      "type": "terrain",
      "position": {
        "x": -30,
        "y": 0,
        "z": 0
      },
      "size": {
        "width": 50,
        "height": 50
      },
      "style": {
        "color": "#2d5a27"
      },
      "properties": {
        "terrainConfig": {
          "segments": 128,
          "heightScale": 10,
          "noise": {
